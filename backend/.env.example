# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# JWT
JWT_SECRET=guclu_bir_rastgele_string_buraya

# Dış API Anahtarları
# FINNHUB_KEY opsiyonel — yoksa yalnızca Yahoo Finance çalışır (yedek devre dışı)
FINNHUB_KEY=your_finnhub_api_key

# Resend (mail doğrulama)
# resend.com'dan ücretsiz API anahtarı al → Ayarlar > API Keys
# Domain doğrulaması yapılmadıysa sadece kendi e-postana gönderebilirsin (test için yeterli)
RESEND_API_KEY=re_your_api_key_here
# Domain doğrulandıktan sonra aşağıdakini güncelle:
RESEND_FROM_EMAIL=Finly <noreply@yourdomain.com>

# Sunucu (opsiyonel, varsayılan 3000)
PORT=3000
